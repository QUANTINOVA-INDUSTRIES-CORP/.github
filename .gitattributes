# Enforce LF line endings for text; keep the repository byte-consistent across platforms.
* text=auto eol=lf

# Explicit text types
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt  text eol=lf

# Treat common binaries as binary
*.png  binary
*.jpg  binary
*.ico  binary
*.pdf  binary
